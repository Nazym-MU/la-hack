# Root env for the offline pipeline (pipeline/build.js loads ../.env then ./.env).
# Copy to .env (gitignored) and paste your keys. The TRIPO key lives separately
# in server/.env — this file is only for the palace-generation pipeline.

# World Labs Marble — needed for `npm run build:generate` (real worlds).
WORLDLABS_API_KEY=

# The clustering + Marble-prompt-writing agent. Pick ONE:
#  - Groq (free, hosted open-source Llama/Qwen) -> provider "openai". Recommended.
GROQ_API_KEY=
#  - Anthropic Claude -> provider "claude".
ANTHROPIC_API_KEY=
#  - Or any other OpenAI-compatible endpoint (OpenRouter, Together, …).
OPENAI_API_KEY=

# Optional: only if you wire the Gemini provider (pipeline/llm.js runGemini seam).
GEMINI_API_KEY=
