<style>
  .panel-container {
    padding: 2.5;
    width: 46;
    display: flex;
    flex-direction: column;
    background-color: #1c1b1a;
    border-color: #3a3733;
    border-width: 0.15;
    border-radius: 1.5;
  }

  .header-row {
    width: 100%;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
  }

  .memory-title {
    font-size: 2;
    color: #e8e6e1;
    font-weight: medium;
  }

  #close-button {
    font-size: 2;
    color: #8a8579;
    padding: 0.5;
    cursor: pointer;
  }

  .divider {
    width: 100%;
    height: 0.08;
    margin-top: 1;
    margin-bottom: 1;
    background-color: #3a3733;
  }

  .memory-text {
    font-size: 1.4;
    color: #b8b3ab;
    text-align: left;
  }

  .memory-date {
    font-size: 1.05;
