    margin-top: 0.8;
    text-align: left;
  }
</style>
<div class="panel-container">
  <div class="header-row">
    <span id="memory-title" class="memory-title">A memory</span>
    <span id="close-button">×</span>
  </div>
  <div class="divider"></div>
  <span id="memory-text" class="memory-text"></span>
  <span id="memory-date" class="memory-date"></span>
</div>
